# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/digital_employee_memo

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_BACKEND_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# Application
DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Reminder Policy (JSON)
REMINDER_POLICY={"immediate":{"delay":0,"methods":["in_app"]},"2h":{"delay":7200,"methods":["in_app","email"]},"24h":{"delay":86400,"methods":["in_app","email"]},"48h":{"delay":172800,"methods":["in_app","email","wechat"]},"72h":{"delay":259200,"methods":["in_app","email","wechat","sms"],"escalate_to":"secretary"}}

# Notification Settings
NOTIFICATION_EMAIL_ENABLED=true
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=notification@example.com
EMAIL_PASSWORD=email_password
EMAIL_FROM=notification@example.com

# Leader Dashboard
DEFAULT_LEADER_ID=1
